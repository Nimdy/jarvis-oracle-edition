# Jarvis Pi 5 Senses — Environment Variables

# Laptop brain connection (required — set to your laptop's LAN IP)
BRAIN_HOST=192.168.1.100
BRAIN_PORT=9100

# Audio devices (name substrings — matched case-insensitively against sounddevice)
# MIC_NAME=JOUNIVO
# SPEAKER_NAME=USB Device

# Whisper STT model (leave empty to use default path)
# WHISPER_MODEL=/path/to/ggml-base.en-q5_1.bin

# Piper TTS model (leave empty to use default path)
# PIPER_MODEL=/path/to/en_GB-semaine-medium.onnx

# Hailo models (leave empty to use defaults from pi/models/)
# HAILO_DET_MODEL=yolov8s
# HAILO_FACE_MODEL=scrfd_2.5g

# UI particle display
UI_PORT=8080

# Logging
LOG_LEVEL=INFO
