# Jarvis Brain — Environment Variables
#
# GPU/VRAM-Aware Configuration:
# The system auto-detects your GPU and selects models automatically.
# Set JARVIS_GPU_TIER to override auto-detection, or set individual
# model env vars to override specific choices.
#
# Tiers:     VRAM     LLM          Vision            STT             Keep-alive
# ─────────────────────────────────────────────────────────────────────────────
# minimal    <4GB     qwen3:1.7b   disabled          tiny (CPU)      5m
# low        4-6GB    qwen3:4b     disabled          small (GPU)     5m
# medium     6-8GB    qwen3:8b     disabled          medium (GPU)    5m
# high       8-12GB   qwen3:8b     qwen2.5vl:7b   large-v3-turbo  10m
# premium    12-16GB  qwen3:8b     qwen2.5vl:7b   large-v3        30m
# ultra      16-24GB  qwen3:14b    qwen2.5vl:7b   large-v3        always
# extreme    24GB+    qwen3:32b    qwen2.5vl:7b   large-v3        always
#
# "always" = models stay loaded in VRAM permanently (keep_alive=-1)

# ── Hardware Tier Override ───────────────────────────────────────────────────
# Auto-detected from GPU VRAM if not set
# JARVIS_GPU_TIER=premium
# JARVIS_CPU_TIER=                   # Force CPU tier override (auto-detected)

# ── Ollama (Local LLM + Vision) ─────────────────────────────────────────────
# These override the tier defaults
OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=qwen3:8b
# OLLAMA_FAST_MODEL=qwen3:4b
# OLLAMA_VISION_MODEL=qwen2.5vl:7b
# OLLAMA_KEEP_ALIVE=-1

# ── Coding LLM (CPU-resident, separate Ollama instance) ─────────────────────
# CODING_MODEL=qwen2.5-coder:7b     # CPU-resident coding LLM model
# CODING_OLLAMA_HOST=http://localhost:11435  # Separate Ollama host for coding
# CODING_BACKEND=ollama-cpu          # ollama-cpu or llama-cpp

# ── Self-Improvement Coder (Qwen3-Coder-Next via llama-server) ───────────────
# Local 80B MoE model for high-accuracy code generation (CPU, ~25-46GB RAM).
# Server starts on-demand per generation and shuts down after to reclaim RAM.
#
# Quant is auto-selected by system RAM during setup.sh:
#   56GB+ RAM → UD-Q4_K_XL  (~46GB, best quality)
#   48-55GB   → UD-IQ4_XS   (~38GB, good quality)
#   32-47GB   → UD-IQ2_M    (~25GB, acceptable quality)
#   <32GB     → disabled (would OOM — do NOT force-enable)
#
# setup.sh writes CODER_MODEL_PATH automatically after download.
ENABLE_CODER_MODEL=true
# CODER_MODEL_PATH=                    # Auto-set by setup.sh (RAM-selected quant)
# CODER_SERVER_PORT=8081               # llama-server port
# CODER_CTX_SIZE=16384                 # Context window (16k is enough for code)
# CODER_GPU_LAYERS=0                   # 0 = pure CPU (no VRAM contention)
# CODER_LLAMA_SERVER=llama-server      # Path to llama-server binary

# ── TTS (Text-to-Speech) ────────────────────────────────────────────────────
# TTS_ENGINE=kokoro_gpu              # kokoro_gpu, kokoro_cpu, or none
# TTS_VOICE=af_bella                 # Default Kokoro voice
# TTS_SPEED=                         # Speech speed multiplier
# TTS_VOICE_EMPATHETIC=              # Voice for empathetic tone
# TTS_VOICE_GUARDED=                 # Voice for guarded tone
# TTS_VOICE_OBSERVATIONAL=           # Voice for observational tone
# TTS_VOICE_SOLEMN=                  # Voice for solemn tone
# TTS_VOICE_URGENT=                  # Voice for urgent tone

# ── OBS Audio Forwarding ────────────────────────────────────────────────────
# Forward Jarvis TTS audio to a remote OBS machine via TCP.
# Set to IP:PORT of your streaming PC running obs_audio_receiver.py.
# Unset = disabled. Pure outbound TCP, zero brain contamination.
# OBS_AUDIO_TARGET=192.168.1.6:5004

# ── STT (Speech-to-Text) ────────────────────────────────────────────────────
# Overrides tier default (see https://huggingface.co/Systran)
# STT_MODEL=large-v3-turbo
# STT_COMPUTE_TYPE=float16           # int8, int8_float16, or float16

# ── API Keys ────────────────────────────────────────────────────────────────
# Anthropic Claude optional plugin provider.
# Not used by default; only enable if you explicitly want an external API path.
# Requires BOTH the API key AND ENABLE_CLAUDE=true to activate.
#ANTHROPIC_API_KEY=
#ENABLE_CLAUDE=false
# OPENAI_API_KEY=                    # OpenAI optional plugin provider for operators who want it

# ── Network ──────────────────────────────────────────────────────────────────
# Perception server (Pi connects here)
PERCEPTION_PORT=9100

# Pi 5 Senses
# PI_HOST=192.168.1.xxx              # Pi IP for camera feed on dashboard
# PI_UI_PORT=8080                    # Pi UI server port for vision tool URL

# Dashboard
DASHBOARD_PORT=9200
# DASHBOARD_API_KEY=                 # API key for dashboard POST endpoints (auto-generated if empty)

# ── Research APIs ────────────────────────────────────────────────────────────
# All work without keys; keys give higher rate limits
# S2_API_KEY=                        # Semantic Scholar API key
# S2 auth uses Bearer token header when key is set.
# S2_AUTH_MIN_INTERVAL_S=1.05        # Min delay between authenticated S2 requests
# CROSSREF_MAILTO=                   # Crossref polite pool email
# RESEARCH_FETCH_OPEN_ACCESS=true    # Fetch open-access full text when available
# RESEARCH_FETCH_FULL_TEXT=true      # Download paper content (PDF/HTML) for study
# RESEARCH_LLM_STUDY=true           # Use LLM for structured knowledge extraction

# ── Feature Flags ────────────────────────────────────────────────────────────
ENABLE_PERCEPTION=true
ENABLE_SCREEN=false
ENABLE_SELF_IMPROVE=true
ENABLE_MULTIMODAL=false
# ENABLE_SPEAKER_ID=                 # Speaker identification on GPU (tier-dependent)
# ENABLE_EMOTION=                    # Audio emotion detection on GPU (tier-dependent)
# ENABLE_AUTONOMY=                   # Autonomous research pipeline (tier-dependent; true on high+)
# ENABLE_GESTATION=true              # Birth protocol for fresh brains (set false to skip)
# ENABLE_ONBOARDING=true             # Companion training playbook automation (set false to skip)
# GESTATION_MIN_DURATION=7200        # Minimum gestation seconds (default 2hrs)

# ── Language Runtime Bridge (Phase D, Guarded) ──────────────────────────────
# Default is OFF. Use canary before full rollout.
# ENABLE_LANGUAGE_RUNTIME_BRIDGE=false
# LANGUAGE_RUNTIME_ROLLOUT_MODE=off  # off, canary, full
# LANGUAGE_RUNTIME_CANARY_CLASSES=self_introspection

# ── Self-Improvement Controls ────────────────────────────────────────────────
# Stage system (primary control): 0=frozen, 1=dry-run, 2=human-approval.
# Takes precedence over FREEZE_AUTO_IMPROVE when set.
# SELF_IMPROVE_STAGE=0
# FREEZE_AUTO_IMPROVE=true           # Legacy: true→stage 0, false→stage 1
# SELF_IMPROVE_DRY_RUN=false         # Generate patches but don't apply them
# Default self-improvement path is local-first:
# local CoderServer -> local Ollama fallback.
# Cloud codegen + cloud patch review (Anthropic/OpenAI) require explicit opt-in:
# SELF_IMPROVE_ALLOW_CLOUD_PROVIDERS=false

# ── Device Overrides ────────────────────────────────────────────────────────
# Override which device (cpu/cuda) runs each subsystem (tier-dependent defaults)
# EMOTION_DEVICE=cuda
# SPEAKER_ID_DEVICE=cuda
# EMBEDDING_DEVICE=cuda              # Memory embedding device
# HEMISPHERE_DEVICE=cuda             # Hemisphere NN device

# ── Memory & Cortex ─────────────────────────────────────────────────────────
# CORTEX_REHYDRATE_ON_BOOT=true      # Warm-start memory cortex from JSONL on boot
# BLUE_DIAMONDS_PATH=~/.jarvis_blue_diamonds/  # Override Blue Diamonds archive path

# ── Synthetic Exercise ───────────────────────────────────────────────────────
# Synthetic perception exercise for training distillation specialists.
# Only useful AFTER Stage 0 Awakening is complete (see docs/AWAKENING_PROTOCOL.md).
# ENABLE_SYNTHETIC_EXERCISE=false
# SYNTHETIC_EXERCISE_RATE_LIMIT=120  # Max utterances per hour

# ── HRR / Holographic Cognition (Shadow Substrate) ──────────────────────────
# Shadow-only, zero authority. Enables HRR encoding to start accumulating
# evidence for specialist promotion. Both default OFF in code; enable here
# for a fully-functioning brain. P5 spatial scene requires BOTH flags.
ENABLE_HRR_SHADOW=true
ENABLE_HRR_SPATIAL_SCENE=true

# ── Advanced ─────────────────────────────────────────────────────────────────
# JARVIS_HOME=~/.jarvis              # Override data + models directory root
# JARVIS_MAX_MEMORIES=2000           # Max memory storage capacity
# ENABLE_DASHBOARD_CHAT=false        # Enable chat widget on dashboard

# ── Debug ────────────────────────────────────────────────────────────────────
# JARVIS_INTROSPECTION_DEBUG=false   # Force all introspection sections
# JARVIS_SUPERVISOR_DEBUG=false      # Disable supervisor backoff for development
